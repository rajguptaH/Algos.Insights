@page
@model ExceptionsModel
@{
    ViewData["AlgosPage"] = "exceptions";
}

<header class="topbar">
  <div>
    <div class="eyebrow">Errors and stack traces</div>
    <h1>Exceptions</h1>
  </div>
</header>

<section class="toolbar compact">
  <div class="search-wrap">
    <span>Search</span>
    <input id="searchInput" type="search" placeholder="Type, message, trace id">
  </div>
</section>

<section class="panel">
  <div class="panel-heading">
    <div>
      <div class="tiny-label">Failures</div>
      <h2>Exception Groups</h2>
    </div>
    <div class="inline-count" id="exceptionCount">0 rows</div>
  </div>
  <div id="exceptionTable" class="table-host"></div>
</section>

@section Scripts {
  <script src="@Model.Route/assets/exceptions.js"></script>
}
